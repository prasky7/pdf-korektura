# .clineignore
# Prevents Cline from indexing heavy framework directories and build artifacts

# ---------------------------------------------------------------------
# PHP / Laravel Specific
# ---------------------------------------------------------------------
/vendor/
/storage/framework/
/storage/logs/
/storage/app/public/
Bootstrap/cache/
.phpunit.result.cache
.php_cs.cache
Homestead.json
Homestead.yaml
.env
.env.backup
.env.production

# ---------------------------------------------------------------------
# JavaScript / React / Frontend Specific
# ---------------------------------------------------------------------
/node_modules/
/public/build/
/public/hot/
/dist/
.pnpm-store/
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------
# IDE, System, and OS Files
# ---------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------
# Optional: Database and Dumps
# ---------------------------------------------------------------------
*.sqlite
*.sql
*.gz